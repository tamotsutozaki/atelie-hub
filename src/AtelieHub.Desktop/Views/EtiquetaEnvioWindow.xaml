<Window x:Class="AtelieHub.Desktop.Views.EtiquetaEnvioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Etiqueta de envio"
        Width="600" Height="720" MinWidth="480" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Brand.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brand.Dark}" Padding="28,22">
            <TextBlock Text="{Binding TituloJanela}" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Brand.TextOnDark}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,16,28,16">
            <StackPanel>

                <Border Background="#FBE9CF" CornerRadius="8" Padding="14,10" Margin="0,0,0,14"
                        Visibility="{Binding RemetenteIncompleto, Converter={StaticResource BoolToVis}}">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brand.Text}"
                               Text="O endereço do remetente (sua empresa) está incompleto. A etiqueta será impressa assim mesmo — preencha o endereço da empresa para um remetente completo." />
                </Border>

                <Border Background="#F6D6CE" CornerRadius="8" Padding="14,10" Margin="0,0,0,14"
                        Visibility="{Binding DestinatarioIncompleto, Converter={StaticResource BoolToVis}}">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Brand.Text}"
                               Text="Este cliente não tem endereço de entrega cadastrado. Edite o cliente para incluir o endereço antes de enviar." />
                </Border>

                <!-- Pré-visualização da etiqueta (representa o que será impresso) -->
                <Border Background="White" BorderBrush="#222222" BorderThickness="1" CornerRadius="4" Padding="22">
                    <StackPanel>
                        <Border BorderBrush="#222222" BorderThickness="2" Padding="16" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="DESTINATÁRIO" FontSize="11" FontWeight="SemiBold" Foreground="#777777" />
                                <TextBlock Text="{Binding DestinatarioNome}" FontSize="22" FontWeight="Bold"
                                           Foreground="Black" TextWrapping="Wrap" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding DestinatarioEndereco}" FontSize="14" Foreground="Black"
                                           TextWrapping="Wrap" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding DestinatarioContato}" FontSize="14" Foreground="Black"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="#222222" BorderThickness="1" Padding="14">
                            <StackPanel>
                                <TextBlock Text="REMETENTE" FontSize="10" FontWeight="SemiBold" Foreground="#777777" />
                                <TextBlock Text="{Binding RemetenteNome}" FontSize="15" FontWeight="Bold"
                                           Foreground="Black" TextWrapping="Wrap" Margin="0,3,0,0" />
                                <TextBlock Text="{Binding RemetenteEndereco}" FontSize="12" Foreground="Black"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding RemetenteContato}" FontSize="12" Foreground="Black"
                                           TextWrapping="Wrap" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource Brand.Card}" Padding="28,16"
                BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Fechar" IsCancel="True" Padding="20,10" Margin="0,0,10,0" />
                <Button Content="Imprimir" Style="{StaticResource Botao.Primario}"
                        IsDefault="True" Command="{Binding ImprimirCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
