<UserControl x:Class="AtelieHub.Desktop.Views.Pages.PedidosPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{StaticResource Brand.Surface}">

    <UserControl.Resources>
        <Style x:Key="CabecalhoColuna" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brand.Dark}" />
            <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:TextBox Width="260" PlaceholderText="Buscar por título ou cliente..."
                            Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                <ComboBox Width="200" Margin="12,0,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding FiltrosStatus}" DisplayMemberPath="Texto"
                          SelectedValuePath="Valor" SelectedValue="{Binding FiltroStatus}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Editar" Command="{Binding EditarCommand}"
                        Padding="16,10" Margin="0,0,10,0" />
                <Button Content="+ Novo pedido" Style="{StaticResource Botao.Primario}"
                        Command="{Binding NovoCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GradePedidos"
                      ItemsSource="{Binding Pedidos}"
                      SelectedItem="{Binding PedidoSelecionado}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource CabecalhoColuna}"
                      MouseDoubleClick="GradePedidos_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Numero}" Width="50" />
                    <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nome}" Width="1.4*" />
                    <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="1.6*" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status, Converter={StaticResource EnumDescricao}}" Width="*" />
                    <DataGridTextColumn Header="Prazo" Binding="{Binding PrazoEntrega, StringFormat=d}" Width="100" />
                    <DataGridTextColumn Header="Valor" Binding="{Binding ValorTotal, StringFormat=C}" Width="110" />
                    <DataGridTextColumn Header="Pagamento"
                                        Binding="{Binding StatusPagamento, Converter={StaticResource EnumDescricao}}" Width="110" />
                    <DataGridCheckBoxColumn Header="Urg." Binding="{Binding Urgente}" Width="50" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding Resumo}" Margin="4,12,0,0"
                   Foreground="{StaticResource Brand.TextMuted}" FontSize="13" />
    </Grid>
</UserControl>
