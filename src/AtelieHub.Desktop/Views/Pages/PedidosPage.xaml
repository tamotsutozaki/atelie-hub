<UserControl x:Class="AtelieHub.Desktop.Views.Pages.PedidosPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{StaticResource Brand.Surface}">

    <UserControl.Resources>
        <Style x:Key="CabecalhoColuna" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brand.Dark}" />
            <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <!-- Pill de filtro (cápsula clicável, estilo Modrinth). Seleção única via ListBox. -->
        <Style x:Key="PillFiltro" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource Brand.Text}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="pill" CornerRadius="16" Padding="14,7"
                                Background="{StaticResource Brand.SandLight}"
                                BorderBrush="{StaticResource Brand.Sand}" BorderThickness="1">
                            <ContentPresenter VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource Brand.Sand}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource Brand.Primary}" />
                                <Setter TargetName="pill" Property="BorderBrush" Value="{StaticResource Brand.Primary}" />
                                <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle em forma de pill (segmento Lista / Quadro). -->
        <Style x:Key="PillToggle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource Brand.Text}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="pill" CornerRadius="16" Padding="14,7"
                                Background="{StaticResource Brand.SandLight}"
                                BorderBrush="{StaticResource Brand.Sand}" BorderThickness="1">
                            <ContentPresenter VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource Brand.Sand}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="pill" Property="Background" Value="{StaticResource Brand.Primary}" />
                                <Setter TargetName="pill" Property="BorderBrush" Value="{StaticResource Brand.Primary}" />
                                <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">

            <!-- Linha 1: busca (preenche) + ações principais -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox Grid.Column="0" VerticalAlignment="Center" MinHeight="42"
                            PlaceholderText="Buscar por título ou cliente..."
                            Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged, Delay=250}">
                    <ui:TextBox.Icon>
                        <ui:SymbolIcon Symbol="Search24" />
                    </ui:TextBox.Icon>
                </ui:TextBox>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Button Content="+ Novo pedido" Style="{StaticResource Botao.Primario}"
                            Command="{Binding NovoCommand}" Margin="0,0,10,0" />
                    <Button Content="Modo Foco" Style="{StaticResource Botao.Acento}"
                            Command="{Binding ModoFocoCommand}" />
                </StackPanel>
            </Grid>

            <!-- Linha 2: funil + pills de status (preenchem e quebram) + visão e ações contextuais -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0">
                    <ui:SymbolIcon DockPanel.Dock="Left" Symbol="Filter24" FontSize="18"
                                   VerticalAlignment="Top" Margin="0,9,12,0"
                                   Foreground="{StaticResource Brand.TextMuted}" />
                    <ListBox ItemsSource="{Binding FiltrosStatus}"
                             SelectedItem="{Binding FiltroStatusSelecionado}"
                             Background="Transparent" BorderThickness="0" Padding="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource PillFiltro}">
                        <ListBox.Style>
                            <Style TargetType="ListBox">
                                <Style.Triggers>
                                    <!-- No Quadro as colunas já são os status; o filtro não se aplica. -->
                                    <DataTrigger Binding="{Binding ModoQuadro}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                        <Setter Property="Opacity" Value="0.5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.Style>
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Texto}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top"
                            Margin="12,0,0,0">
                    <RadioButton Content="Lista" GroupName="ModoView" IsChecked="True"
                                 Style="{StaticResource PillToggle}" />
                    <RadioButton Content="Quadro" GroupName="ModoView" IsChecked="{Binding ModoQuadro}"
                                 Style="{StaticResource PillToggle}" />
                    <Border Width="1" Background="{StaticResource Brand.SandLight}" Margin="4,2,12,2" />
                    <Button Content="Editar" Command="{Binding EditarCommand}"
                            Padding="16,10" Margin="0,0,10,0" />
                    <Button Content="Etiqueta" Command="{Binding EtiquetaCommand}"
                            Padding="16,10" Margin="0,0,10,0" />
                    <Button Content="Excluir" Style="{StaticResource Botao.Perigo}"
                            Command="{Binding ExcluirCommand}" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1">
            <!-- Visão LISTA -->
            <Border Padding="0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ModoQuadro}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DataGrid x:Name="GradePedidos"
                          ItemsSource="{Binding Pedidos}"
                          SelectedItem="{Binding PedidoSelecionado}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeight="40"
                          Background="Transparent"
                          BorderThickness="0"
                          ColumnHeaderStyle="{StaticResource CabecalhoColuna}"
                          MouseDoubleClick="GradePedidos_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Numero}" Width="50" />
                        <DataGridTextColumn Header="Cliente" Binding="{Binding Cliente.Nome}" Width="1.4*" />
                        <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="1.6*" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status, Converter={StaticResource EnumDescricao}}" Width="*" />
                        <DataGridTextColumn Header="Prazo" Binding="{Binding PrazoEntrega, StringFormat=d}" Width="100" />
                        <DataGridTextColumn Header="Valor" Binding="{Binding ValorTotal, StringFormat=C}" Width="110" />
                        <DataGridTextColumn Header="Pagamento"
                                            Binding="{Binding StatusPagamento, Converter={StaticResource EnumDescricao}}" Width="110" />
                        <DataGridCheckBoxColumn Header="Urg." Binding="{Binding Urgente}" Width="50" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Visão QUADRO (Kanban) -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Visibility="{Binding ModoQuadro, Converter={StaticResource BoolToVis}}">
                <ItemsControl ItemsSource="{Binding Colunas}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="248" Margin="0,0,12,0"
                                    Height="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                    Background="{StaticResource Brand.Card}" CornerRadius="12"
                                    BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="1"
                                    AllowDrop="True" DragOver="Coluna_DragOver" Drop="Coluna_Drop">
                                <DockPanel Margin="12">
                                    <Grid DockPanel.Dock="Top" Margin="2,0,2,10">
                                        <TextBlock Text="{Binding Titulo}" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource Brand.Text}" TextWrapping="Wrap" />
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Background="{StaticResource Brand.SandLight}" CornerRadius="10" Padding="8,2">
                                            <TextBlock Text="{Binding Itens.Count}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Brand.TextMuted}" />
                                        </Border>
                                    </Grid>

                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsControl ItemsSource="{Binding Itens}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="8"
                                                            Padding="12" Margin="0,0,0,8" Cursor="Hand"
                                                            AllowDrop="True"
                                                            PreviewMouseLeftButtonDown="Card_PreviewMouseLeftButtonDown"
                                                            MouseMove="Card_MouseMove">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource Brand.SandLight}" />
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource Brand.Sand}" />
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <StackPanel>
                                                            <Grid>
                                                                <TextBlock Text="{Binding Numero, StringFormat='#{0}'}"
                                                                           FontSize="12" FontWeight="Bold"
                                                                           Foreground="{StaticResource Brand.TextMuted}" />
                                                                <Ellipse Width="12" Height="12" HorizontalAlignment="Right"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding Prioridade, Converter={StaticResource PrioridadeCor}}"
                                                                         ToolTip="{Binding Prioridade, Converter={StaticResource EnumDescricao}}" />
                                                            </Grid>
                                                            <TextBlock Text="{Binding Titulo}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{StaticResource Brand.Text}" TextWrapping="Wrap"
                                                                       Margin="0,4,0,0" />
                                                            <TextBlock Text="{Binding Cliente.Nome}" FontSize="12"
                                                                       Foreground="{StaticResource Brand.TextMuted}"
                                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                                            <Grid Margin="0,6,0,0">
                                                                <TextBlock Text="{Binding PrazoEntrega, StringFormat='Prazo: {0:d}'}"
                                                                           FontSize="11" Foreground="{StaticResource Brand.TextMuted}" />
                                                                <Border HorizontalAlignment="Right" Background="#B23B3B"
                                                                        CornerRadius="5" Padding="6,1"
                                                                        Visibility="{Binding Urgente, Converter={StaticResource BoolToVis}}">
                                                                    <TextBlock Text="urgente" FontSize="10" FontWeight="Bold"
                                                                               Foreground="White" />
                                                                </Border>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding Resumo}" Margin="4,12,0,0"
                   Foreground="{StaticResource Brand.TextMuted}" FontSize="13" />
    </Grid>
</UserControl>
