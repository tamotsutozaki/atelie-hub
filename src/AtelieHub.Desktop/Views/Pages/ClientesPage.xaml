<UserControl x:Class="AtelieHub.Desktop.Views.Pages.ClientesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{StaticResource Brand.Surface}">

    <UserControl.Resources>
        <Style x:Key="CabecalhoColuna" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brand.Dark}" />
            <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barra de ações -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ui:TextBox Width="300" PlaceholderText="Buscar por nome, telefone, e-mail..."
                            Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged, Delay=250}" />
                <CheckBox Content="Mostrar inativos" IsChecked="{Binding MostrarInativos}"
                          VerticalAlignment="Center" Margin="16,0,0,0"
                          Foreground="{StaticResource Brand.Text}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Inativar / Reativar" Command="{Binding AlternarAtivoCommand}"
                        Padding="16,10" Margin="0,0,10,0" />
                <Button Content="Editar" Command="{Binding EditarCommand}"
                        Padding="16,10" Margin="0,0,10,0" />
                <Button Content="+ Novo cliente" Style="{StaticResource Botao.Primario}"
                        Command="{Binding NovoCommand}" />
            </StackPanel>
        </Grid>

        <!-- Lista -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GradeClientes"
                      ItemsSource="{Binding Clientes}"
                      SelectedItem="{Binding ClienteSelecionado}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="40"
                      Background="Transparent"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource CabecalhoColuna}"
                      MouseDoubleClick="GradeClientes_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="2*" />
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="*" />
                    <DataGridTextColumn Header="Cidade" Binding="{Binding Cidade}" Width="*" />
                    <DataGridTextColumn Header="Instagram" Binding="{Binding Instagram}" Width="*" />
                    <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Ativo}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Rodapé -->
        <TextBlock Grid.Row="2" Text="{Binding Resumo}" Margin="4,12,0,0"
                   Foreground="{StaticResource Brand.TextMuted}" FontSize="13" />
    </Grid>
</UserControl>
