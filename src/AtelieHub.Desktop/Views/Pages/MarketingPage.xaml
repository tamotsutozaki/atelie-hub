<UserControl x:Class="AtelieHub.Desktop.Views.Pages.MarketingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brand.Surface}">

    <UserControl.Resources>
        <Style x:Key="CabecalhoColuna" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brand.Dark}" />
            <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0" Content="Mostrar concluídos" IsChecked="{Binding IncluirConcluidas}"
                      VerticalAlignment="Center" Foreground="{StaticResource Brand.Text}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Concluir / Reabrir" Command="{Binding AlternarConcluidoCommand}"
                        Padding="16,10" Margin="0,0,10,0" />
                <Button Content="Remover" Command="{Binding RemoverCommand}" Padding="16,10" Margin="0,0,10,0" />
                <Button Content="Editar" Command="{Binding EditarCommand}" Padding="16,10" Margin="0,0,10,0" />
                <Button Content="+ Novo lembrete" Style="{StaticResource Botao.Primario}"
                        Command="{Binding NovoCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GradeMarketing"
                      ItemsSource="{Binding Tarefas}"
                      SelectedItem="{Binding Selecionada}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="38"
                      Background="Transparent"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource CabecalhoColuna}"
                      MouseDoubleClick="GradeMarketing_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="2*" />
                    <DataGridTextColumn Header="Rede"
                                        Binding="{Binding Rede, Converter={StaticResource EnumDescricao}}" Width="*" />
                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="*" />
                    <DataGridTextColumn Header="Prevista" Binding="{Binding DataPrevista, StringFormat=d}" Width="110" />
                    <DataGridCheckBoxColumn Header="Feito" Binding="{Binding Concluido}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding Resumo}" Margin="4,12,0,0"
                   Foreground="{StaticResource Brand.TextMuted}" FontSize="13" />
    </Grid>
</UserControl>
