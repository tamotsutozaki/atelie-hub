<UserControl x:Class="AtelieHub.Desktop.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Background="{StaticResource Brand.Surface}">

    <UserControl.Resources>
        <!-- Uma linha da lista de um indicador (o que o número representa) -->
        <DataTemplate x:Key="ItemIndicador">
            <Border Padding="0,6" BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding Texto}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Brand.Text}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Detalhe}" FontSize="11" Margin="0,2,0,0"
                               Foreground="{StaticResource Brand.TextMuted}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28">
        <StackPanel>

            <!-- Saudação + ações -->
            <Border Style="{StaticResource Card}" Background="{StaticResource Brand.Dark}" Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Saudacao}" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource Brand.TextOnDark}" TextWrapping="Wrap" />
                        <TextBlock Text="Aqui você acompanha o dia a dia do seu ateliê num lugar só."
                                   FontSize="14" Margin="0,8,0,0" Foreground="{StaticResource Brand.Sand}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Fazendo backup..." VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="13" Foreground="{StaticResource Brand.Sand}"
                                   Visibility="{Binding Ocupado, Converter={StaticResource BoolToVis}}" />
                        <Button ToolTip="Atualizar" Command="{Binding AtualizarCommand}"
                                Width="46" Height="46" Padding="0" Margin="0,0,10,0">
                            <ui:SymbolIcon Symbol="ArrowClockwise24" FontSize="20" />
                        </Button>
                        <Button ToolTip="Fazer backup" Style="{StaticResource Botao.Primario}"
                                Command="{Binding FazerBackupCommand}" Width="46" Height="46" Padding="0">
                            <ui:SymbolIcon Symbol="Save24" FontSize="20"
                                           Foreground="{StaticResource Brand.TextOnDark}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Aviso de falha ao carregar os números -->
            <Border Margin="0,12,0,0" Padding="14,10" CornerRadius="8" Background="#F6D6CE"
                    Visibility="{Binding ErroAoCarregar, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Não foi possível carregar os números do painel. Verifique se o banco está disponível e clique em Atualizar."
                           TextWrapping="Wrap" Foreground="{StaticResource Brand.PrimaryDark}" />
            </Border>

            <!-- Indicadores -->
            <UniformGrid Rows="2" Columns="3" Margin="0,18,0,0">

                <!-- Pedidos em aberto -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Pedidos em aberto" FontSize="13"
                                   Foreground="{StaticResource Brand.TextMuted}" />
                        <TextBlock DockPanel.Dock="Top" Text="{Binding PedidosEmAberto}" FontSize="28"
                                   FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource Brand.Primary}" />
                        <Border DockPanel.Dock="Top" Height="1" Margin="0,8,0,6"
                                Background="{StaticResource Brand.SandLight}" />
                        <Grid>
                            <TextBlock Text="Nada em aberto." FontSize="12" Foreground="{StaticResource Brand.TextMuted}"
                                       Visibility="{Binding PedidosEmAbertoItens.Count, Converter={StaticResource ZeroParaVisivel}}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                <ItemsControl ItemsSource="{Binding PedidosEmAbertoItens}"
                                              ItemTemplate="{StaticResource ItemIndicador}" />
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- A entregar -->
                <Border Style="{StaticResource Card}" Margin="8,0,8,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="A entregar" FontSize="13"
                                   Foreground="{StaticResource Brand.TextMuted}" />
                        <TextBlock DockPanel.Dock="Top" Text="{Binding AEntregar}" FontSize="28"
                                   FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource Brand.Primary}" />
                        <Border DockPanel.Dock="Top" Height="1" Margin="0,8,0,6"
                                Background="{StaticResource Brand.SandLight}" />
                        <Grid>
                            <TextBlock Text="Nada pronto para entregar." FontSize="12" Foreground="{StaticResource Brand.TextMuted}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding AEntregarItens.Count, Converter={StaticResource ZeroParaVisivel}}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                <ItemsControl ItemsSource="{Binding AEntregarItens}"
                                              ItemTemplate="{StaticResource ItemIndicador}" />
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Pendências de pagamento -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Pendências de pagamento" FontSize="13"
                                   Foreground="{StaticResource Brand.TextMuted}" />
                        <TextBlock DockPanel.Dock="Top" Text="{Binding PendenciasFinanceiras}" FontSize="28"
                                   FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource Brand.Accent}" />
                        <Border DockPanel.Dock="Top" Height="1" Margin="0,8,0,6"
                                Background="{StaticResource Brand.SandLight}" />
                        <Grid>
                            <TextBlock Text="Nenhuma pendência." FontSize="12" Foreground="{StaticResource Brand.TextMuted}"
                                       Visibility="{Binding PendenciasFinanceirasItens.Count, Converter={StaticResource ZeroParaVisivel}}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                <ItemsControl ItemsSource="{Binding PendenciasFinanceirasItens}"
                                              ItemTemplate="{StaticResource ItemIndicador}" />
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Estoque baixo -->
                <Border Style="{StaticResource Card}" Margin="0,8,8,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Estoque baixo" FontSize="13"
                                   Foreground="{StaticResource Brand.TextMuted}" />
                        <TextBlock DockPanel.Dock="Top" Text="{Binding EstoqueBaixo}" FontSize="28"
                                   FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource Brand.Accent}" />
                        <Border DockPanel.Dock="Top" Height="1" Margin="0,8,0,6"
                                Background="{StaticResource Brand.SandLight}" />
                        <Grid>
                            <TextBlock Text="Estoque em dia." FontSize="12" Foreground="{StaticResource Brand.TextMuted}"
                                       Visibility="{Binding EstoqueBaixoItens.Count, Converter={StaticResource ZeroParaVisivel}}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                <ItemsControl ItemsSource="{Binding EstoqueBaixoItens}"
                                              ItemTemplate="{StaticResource ItemIndicador}" />
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Marketing pendente -->
                <Border Style="{StaticResource Card}" Margin="8,8,8,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Marketing pendente" FontSize="13"
                                   Foreground="{StaticResource Brand.TextMuted}" />
                        <TextBlock DockPanel.Dock="Top" Text="{Binding MarketingPendente}" FontSize="28"
                                   FontWeight="Bold" Margin="0,4,0,0" Foreground="{StaticResource Brand.Primary}" />
                        <Border DockPanel.Dock="Top" Height="1" Margin="0,8,0,6"
                                Background="{StaticResource Brand.SandLight}" />
                        <Grid>
                            <TextBlock Text="Nada pendente." FontSize="12" Foreground="{StaticResource Brand.TextMuted}"
                                       Visibility="{Binding MarketingPendenteItens.Count, Converter={StaticResource ZeroParaVisivel}}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                                <ItemsControl ItemsSource="{Binding MarketingPendenteItens}"
                                              ItemTemplate="{StaticResource ItemIndicador}" />
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Saldo em caixa (mantido como número) -->
                <Border Style="{StaticResource Card}" Margin="8,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Saldo em caixa" FontSize="13" Foreground="{StaticResource Brand.TextMuted}" />
                        <TextBlock Text="{Binding SaldoCaixa, StringFormat=C}" FontSize="32" FontWeight="Bold"
                                   Margin="0,6,0,0" Foreground="{StaticResource Brand.Text}" />
                    </StackPanel>
                </Border>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
