<UserControl x:Class="AtelieHub.Desktop.Views.Pages.FinanceiroPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Brand.Surface}">

    <UserControl.Resources>
        <Style x:Key="CabecalhoColuna" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brand.Dark}" />
            <Setter Property="Foreground" Value="{StaticResource Brand.TextOnDark}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Resumo -->
        <UniformGrid Grid.Row="0" Rows="1" Columns="3" Margin="0,0,0,16">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Entradas" FontSize="13" Foreground="{StaticResource Brand.TextMuted}" />
                    <TextBlock Text="{Binding Entradas, StringFormat=C}" FontSize="26" FontWeight="Bold"
                               Margin="0,6,0,0" Foreground="{StaticResource Brand.Primary}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,8,0">
                <StackPanel>
                    <TextBlock Text="Saídas" FontSize="13" Foreground="{StaticResource Brand.TextMuted}" />
                    <TextBlock Text="{Binding Saidas, StringFormat=C}" FontSize="26" FontWeight="Bold"
                               Margin="0,6,0,0" Foreground="{StaticResource Brand.Accent}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Saldo em caixa" FontSize="13" Foreground="{StaticResource Brand.TextMuted}" />
                    <TextBlock Text="{Binding Saldo, StringFormat=C}" FontSize="26" FontWeight="Bold"
                               Margin="0,6,0,0" Foreground="{StaticResource Brand.Text}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Ações -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16">
            <Button Content="Remover" Command="{Binding RemoverCommand}" Padding="16,10" Margin="0,0,10,0" />
            <Button Content="Editar" Command="{Binding EditarCommand}" Padding="16,10" Margin="0,0,10,0" />
            <Button Content="+ Novo lançamento" Style="{StaticResource Botao.Primario}"
                    Command="{Binding NovoCommand}" />
        </StackPanel>

        <!-- Lista -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GradeLancamentos"
                      ItemsSource="{Binding Lancamentos}"
                      SelectedItem="{Binding Selecionado}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="38"
                      Background="Transparent"
                      BorderThickness="0"
                      ColumnHeaderStyle="{StaticResource CabecalhoColuna}"
                      MouseDoubleClick="GradeLancamentos_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Data" Binding="{Binding Data, StringFormat=d}" Width="110" />
                    <DataGridTextColumn Header="Tipo"
                                        Binding="{Binding Tipo, Converter={StaticResource EnumDescricao}}" Width="100" />
                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="2*" />
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="*" />
                    <DataGridTextColumn Header="Valor" Binding="{Binding Valor, StringFormat=C}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
