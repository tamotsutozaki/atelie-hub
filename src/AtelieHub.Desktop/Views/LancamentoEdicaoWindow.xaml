<Window x:Class="AtelieHub.Desktop.Views.LancamentoEdicaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Lançamento"
        Width="480" Height="520" MinWidth="420" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Brand.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brand.Dark}" Padding="28,22">
            <TextBlock Text="{Binding TituloJanela}" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Brand.TextOnDark}" />
        </Border>

        <StackPanel Grid.Row="1" Margin="28,16">
            <TextBlock Text="Tipo" Style="{StaticResource Campo.Label}" />
            <ComboBox ItemsSource="{Binding TiposDisponiveis}" SelectedItem="{Binding Tipo}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Descrição *" Style="{StaticResource Campo.Label}" />
            <ui:TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Ex.: Pagamento pedido #12 / Compra de papel" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Valor (R$) *" Style="{StaticResource Campo.Label}" />
                    <ui:TextBox Text="{Binding Valor, UpdateSourceTrigger=LostFocus}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Data" Style="{StaticResource Campo.Label}" />
                    <DatePicker SelectedDate="{Binding Data}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="Categoria" Style="{StaticResource Campo.Label}" />
            <ui:TextBox Text="{Binding Categoria, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Ex.: Vendas, Material, Frete..." />
        </StackPanel>

        <Border Grid.Row="2" Background="{StaticResource Brand.Card}" Padding="28,16"
                BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" IsCancel="True" Padding="20,10" Margin="0,0,10,0" />
                <Button Content="Salvar" Style="{StaticResource Botao.Primario}"
                        IsDefault="True" Command="{Binding SalvarCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
