<Window x:Class="AtelieHub.Desktop.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AtelieHub.Desktop.ViewModels"
        xmlns:pages="clr-namespace:AtelieHub.Desktop.Views.Pages"
        Title="Ateliê Hub"
        Width="1150" Height="760"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brand.Surface}">

    <Window.Resources>
        <!-- Mapeia cada ViewModel à sua página -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardPage />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ======== Sidebar ======== -->
        <Border Grid.Column="0" Background="{StaticResource Brand.Dark}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="22,26,22,18">
                    <TextBlock Text="Ateliê Hub" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource Brand.TextOnDark}" />
                    <TextBlock Text="Gestão do seu ateliê" FontSize="12" Margin="0,4,0,0"
                               Foreground="{StaticResource Brand.Sand}" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Margin="22,0,22,18"
                           Text="v0.1 · beta" FontSize="11"
                           Foreground="{StaticResource Brand.Sand}" Opacity="0.7" />

                <StackPanel Margin="0,8,0,0">
                    <Button Content="Painel" Style="{StaticResource Nav.Botao.Ativo}"
                            Command="{Binding NavegarDashboardCommand}" />
                    <Button Content="Clientes" Style="{StaticResource Nav.Botao}" IsEnabled="False" />
                    <Button Content="Pedidos" Style="{StaticResource Nav.Botao}" IsEnabled="False" />
                    <Button Content="Financeiro" Style="{StaticResource Nav.Botao}" IsEnabled="False" />
                    <Button Content="Estoque" Style="{StaticResource Nav.Botao}" IsEnabled="False" />
                    <Button Content="Marketing" Style="{StaticResource Nav.Botao}" IsEnabled="False" />

                    <TextBlock Text="Em breve nos próximos módulos" FontSize="11"
                               Margin="20,12,20,0" TextWrapping="Wrap"
                               Foreground="{StaticResource Brand.Sand}" Opacity="0.7" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ======== Conteúdo ======== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Cabeçalho da seção -->
            <Border Grid.Row="0" Background="{StaticResource Brand.Card}" Padding="28,18"
                    BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="{Binding TituloSecao}" Style="{StaticResource Titulo.Secao}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding NomeEmpresa}" HorizontalAlignment="Right"
                               VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Brand.Primary}" />
                </Grid>
            </Border>

            <!-- Página atual -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="0" />
        </Grid>
    </Grid>
</Window>
