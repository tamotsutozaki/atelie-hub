<Window x:Class="AtelieHub.Desktop.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AtelieHub.Desktop.ViewModels"
        xmlns:pages="clr-namespace:AtelieHub.Desktop.Views.Pages"
        Title="Ateliê Hub"
        Width="1280" Height="800"
        MinWidth="1040" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brand.Surface}">

    <Window.Resources>
        <!-- Mapeia cada ViewModel à sua página -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <pages:DashboardPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
            <pages:ClientesPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PedidosViewModel}">
            <pages:PedidosPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FinanceiroViewModel}">
            <pages:FinanceiroPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EstoqueViewModel}">
            <pages:EstoquePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MarketingViewModel}">
            <pages:MarketingPage />
        </DataTemplate>

        <!-- Item de navegação com destaque dinâmico da seção ativa -->
        <Style x:Key="Nav.Painel" TargetType="Button" BasedOn="{StaticResource Nav.Botao}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SecaoAtiva}" Value="Painel">
                    <Setter Property="Background" Value="{StaticResource Brand.Primary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nav.Clientes" TargetType="Button" BasedOn="{StaticResource Nav.Botao}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SecaoAtiva}" Value="Clientes">
                    <Setter Property="Background" Value="{StaticResource Brand.Primary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nav.Pedidos" TargetType="Button" BasedOn="{StaticResource Nav.Botao}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SecaoAtiva}" Value="Pedidos">
                    <Setter Property="Background" Value="{StaticResource Brand.Primary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nav.Financeiro" TargetType="Button" BasedOn="{StaticResource Nav.Botao}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SecaoAtiva}" Value="Financeiro">
                    <Setter Property="Background" Value="{StaticResource Brand.Primary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nav.Estoque" TargetType="Button" BasedOn="{StaticResource Nav.Botao}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SecaoAtiva}" Value="Estoque">
                    <Setter Property="Background" Value="{StaticResource Brand.Primary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Nav.Marketing" TargetType="Button" BasedOn="{StaticResource Nav.Botao}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SecaoAtiva}" Value="Marketing">
                    <Setter Property="Background" Value="{StaticResource Brand.Primary}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ======== Sidebar ======== -->
        <Border Grid.Column="0" Background="{StaticResource Brand.Dark}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="22,26,22,18">
                    <TextBlock Text="Ateliê Hub" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource Brand.TextOnDark}" />
                    <TextBlock Text="Gestão do seu ateliê" FontSize="12" Margin="0,4,0,0"
                               Foreground="{StaticResource Brand.Sand}" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Margin="22,0,22,18"
                           Text="v0.1 · beta" FontSize="11"
                           Foreground="{StaticResource Brand.Sand}" Opacity="0.7" />

                <StackPanel Margin="0,8,0,0">
                    <Button Content="Painel" Style="{StaticResource Nav.Painel}"
                            Command="{Binding NavegarDashboardCommand}" />
                    <Button Content="Clientes" Style="{StaticResource Nav.Clientes}"
                            Command="{Binding NavegarClientesCommand}" />
                    <Button Content="Pedidos" Style="{StaticResource Nav.Pedidos}"
                            Command="{Binding NavegarPedidosCommand}" />
                    <Button Content="Financeiro" Style="{StaticResource Nav.Financeiro}"
                            Command="{Binding NavegarFinanceiroCommand}" />
                    <Button Content="Estoque" Style="{StaticResource Nav.Estoque}"
                            Command="{Binding NavegarEstoqueCommand}" />
                    <Button Content="Marketing" Style="{StaticResource Nav.Marketing}"
                            Command="{Binding NavegarMarketingCommand}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ======== Conteúdo ======== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Cabeçalho da seção -->
            <Border Grid.Row="0" Background="{StaticResource Brand.Card}" Padding="28,18"
                    BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="{Binding TituloSecao}" Style="{StaticResource Titulo.Secao}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding NomeEmpresa}" HorizontalAlignment="Right"
                               VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Brand.Primary}" />
                </Grid>
            </Border>

            <!-- Página atual -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="0" />
        </Grid>
    </Grid>
</Window>
