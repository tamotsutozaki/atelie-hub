<Window x:Class="AtelieHub.Desktop.Views.PedidoEdicaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Pedido"
        Width="640" Height="860" MinWidth="520" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Brand.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brand.Dark}" Padding="28,22">
            <TextBlock Text="{Binding TituloJanela}" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Brand.TextOnDark}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,8,28,8">
            <StackPanel Margin="0,12,0,12">

                <TextBlock Text="Cliente *" Style="{StaticResource Campo.Label}" />
                <ComboBox ItemsSource="{Binding Clientes}" SelectedItem="{Binding ClienteSelecionado}"
                          DisplayMemberPath="Nome" />

                <TextBlock Text="Título do pedido *" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Titulo, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Ex.: Retrato em aquarela A3" />

                <TextBlock Text="Descrição" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                            MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"
                            PlaceholderText="Detalhes do trabalho" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Tipo" Style="{StaticResource Campo.Label}" />
                        <ComboBox ItemsSource="{Binding TiposDisponiveis}" SelectedItem="{Binding Tipo}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Status de produção" Style="{StaticResource Campo.Label}" />
                        <ComboBox ItemsSource="{Binding StatusDisponiveis}" SelectedItem="{Binding Status}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Prioridade" Style="{StaticResource Campo.Label}" />
                        <ComboBox ItemsSource="{Binding PrioridadesDisponiveis}" SelectedItem="{Binding Prioridade}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <CheckBox Content="Pedido urgente" IsChecked="{Binding Urgente}" Margin="0,0,0,8"
                                  Foreground="{StaticResource Brand.Text}" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Data do pedido" Style="{StaticResource Campo.Label}" />
                        <DatePicker SelectedDate="{Binding DataPedido}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Prazo de entrega" Style="{StaticResource Campo.Label}" />
                        <DatePicker SelectedDate="{Binding PrazoEntrega}" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Valor total (R$)" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding ValorTotal, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Pagamento" Style="{StaticResource Campo.Label}" />
                        <ComboBox ItemsSource="{Binding PagamentosDisponiveis}" SelectedItem="{Binding StatusPagamento}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescricao}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Text="ENVIO" FontSize="12" FontWeight="Bold" Margin="0,20,0,0"
                           Foreground="{StaticResource Brand.Accent}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Transportadora" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Transportadora, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Correios, Jadlog..." />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Código de rastreio" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding CodigoRastreio, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
                <TextBlock Text="Data de postagem" Style="{StaticResource Campo.Label}" />
                <DatePicker SelectedDate="{Binding DataPostagem}" />

                <TextBlock Text="OBSERVAÇÕES" FontSize="12" FontWeight="Bold" Margin="0,20,0,0"
                           Foreground="{StaticResource Brand.Accent}" />
                <ui:TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,8,0,0" MinHeight="70" TextWrapping="Wrap" AcceptsReturn="True"
                            PlaceholderText="Anotações do pedido..." />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource Brand.Card}" Padding="28,16"
                BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" IsCancel="True" Padding="20,10" Margin="0,0,10,0" />
                <Button Content="Salvar" Style="{StaticResource Botao.Primario}"
                        IsDefault="True" Command="{Binding SalvarCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
