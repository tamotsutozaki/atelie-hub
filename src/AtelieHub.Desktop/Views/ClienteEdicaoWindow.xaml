<Window x:Class="AtelieHub.Desktop.Views.ClienteEdicaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Cliente"
        Width="600" Height="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{StaticResource Brand.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{StaticResource Brand.Dark}" Padding="28,22">
            <TextBlock Text="{Binding Titulo}" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Brand.TextOnDark}" />
        </Border>

        <!-- Formulário -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,8,28,8">
            <StackPanel Margin="0,12,0,12">

                <TextBlock Text="CONTATO" FontSize="12" FontWeight="Bold" Margin="0,4,0,0"
                           Foreground="{StaticResource Brand.Accent}" />

                <TextBlock Text="Nome *" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Nome do cliente" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Telefone / WhatsApp" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="(00) 00000-0000" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Instagram" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Instagram, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="@cliente" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="E-mail" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="email@exemplo.com" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Como conheceu" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Origem, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Indicação, Instagram..." />
                    </StackPanel>
                </Grid>

                <TextBlock Text="ENDEREÇO (PARA ENVIO)" FontSize="12" FontWeight="Bold" Margin="0,20,0,0"
                           Foreground="{StaticResource Brand.Accent}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CEP" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Cep, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="00000-000" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Logradouro" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Logradouro, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Rua / Avenida" />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Número" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Numero, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Complemento" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Complemento, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="Apto, bloco..." />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Bairro" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Bairro, UpdateSourceTrigger=PropertyChanged}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cidade" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Cidade, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="UF" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Estado, UpdateSourceTrigger=PropertyChanged}" MaxLength="2" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="OBSERVAÇÕES" FontSize="12" FontWeight="Bold" Margin="0,20,0,0"
                           Foreground="{StaticResource Brand.Accent}" />
                <ui:TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,8,0,0" MinHeight="80" TextWrapping="Wrap" AcceptsReturn="True"
                            PlaceholderText="Preferências, histórico, anotações..." />

                <CheckBox Content="Cliente ativo" IsChecked="{Binding Ativo}" Margin="0,20,0,0"
                          Foreground="{StaticResource Brand.Text}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Rodapé -->
        <Border Grid.Row="2" Background="{StaticResource Brand.Card}" Padding="28,16"
                BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" IsCancel="True" Padding="20,10" Margin="0,0,10,0" />
                <Button Content="Salvar" Style="{StaticResource Botao.Primario}"
                        Command="{Binding SalvarCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
