<Window x:Class="AtelieHub.Desktop.Views.ProdutoEstoqueEdicaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Item de estoque"
        Width="500" Height="600" MinWidth="420" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{StaticResource Brand.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brand.Dark}" Padding="28,22">
            <TextBlock Text="{Binding TituloJanela}" FontSize="22" FontWeight="Bold"
                       Foreground="{StaticResource Brand.TextOnDark}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,8,28,8">
            <StackPanel Margin="0,12,0,12">
                <TextBlock Text="Nome *" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Ex.: Papel canson A3" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Quantidade" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Quantidade, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Unidade" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Unidade, UpdateSourceTrigger=PropertyChanged}"
                                    PlaceholderText="un, m, kg..." />
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Estoque mínimo" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding EstoqueMinimo, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Custo (R$)" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Custo, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="Observações" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}"
                            MinHeight="70" TextWrapping="Wrap" AcceptsReturn="True"
                            PlaceholderText="Fornecedor, marca, anotações..." />

                <CheckBox Content="Item ativo" IsChecked="{Binding Ativo}" Margin="0,20,0,0"
                          Foreground="{StaticResource Brand.Text}" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource Brand.Card}" Padding="28,16"
                BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" IsCancel="True" Padding="20,10" Margin="0,0,10,0" />
                <Button Content="Salvar" Style="{StaticResource Botao.Primario}"
                        IsDefault="True" Command="{Binding SalvarCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
