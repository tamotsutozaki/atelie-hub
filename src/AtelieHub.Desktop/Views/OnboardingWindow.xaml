<Window x:Class="AtelieHub.Desktop.Views.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Bem-vinda ao Ateliê Hub"
        Width="560" Height="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource Brand.Surface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="{StaticResource Brand.Dark}" Padding="32,28">
            <StackPanel>
                <TextBlock Text="Ateliê Hub" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource Brand.TextOnDark}" />
                <TextBlock Text="Vamos configurar o seu ateliê para começar"
                           FontSize="13" Margin="0,6,0,0"
                           Foreground="{StaticResource Brand.Sand}" />
            </StackPanel>
        </Border>

        <!-- Formulário -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,8,32,8">
            <StackPanel Margin="0,16,0,16">
                <TextBlock Text="Nome do ateliê / negócio *" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Ex.: Estúdio Aurora" />

                <TextBlock Text="Seu nome" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding NomeResponsavel, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Como devemos te chamar" />

                <TextBlock Text="CNPJ / CPF" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Opcional" />

                <TextBlock Text="E-mail" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="contato@exemplo.com" />

                <TextBlock Text="Telefone / WhatsApp" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="(00) 00000-0000" />

                <TextBlock Text="Instagram" Style="{StaticResource Campo.Label}" />
                <ui:TextBox Text="{Binding Instagram, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="@seuatelie" />

                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cidade" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Cidade, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="UF" Style="{StaticResource Campo.Label}" />
                        <ui:TextBox Text="{Binding Estado, UpdateSourceTrigger=PropertyChanged}"
                                    MaxLength="2" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="* Só o nome do negócio é obrigatório. O resto você completa depois."
                           FontSize="12" Margin="0,18,0,0" TextWrapping="Wrap"
                           Foreground="{StaticResource Brand.TextMuted}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Rodapé -->
        <Border Grid.Row="2" Background="{StaticResource Brand.Card}" Padding="32,18"
                BorderBrush="{StaticResource Brand.SandLight}" BorderThickness="0,1,0,0">
            <Button Content="Começar a usar" Style="{StaticResource Botao.Primario}"
                    HorizontalAlignment="Right" Command="{Binding SalvarCommand}" />
        </Border>
    </Grid>
</Window>
